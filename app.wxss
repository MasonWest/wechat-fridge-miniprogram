/** app.wxss **/
/* 全局重置与基础样式 */

page {
  font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', 'PingFang SC', 'Hiragino Sans GB',
    'Microsoft YaHei', 'Helvetica Neue', Helvetica, Arial, sans-serif;
  line-height: 1.5;
  color: #2d3a2d;
  background: #f8fcf8;
  font-size: 14px;
}

/* 去除输入框默认样式 */
input, button, textarea {
  font-family: inherit;
  font-size: inherit;
  box-sizing: border-box;
}

/* 按钮样式重置 */
button {
  border: none;
  background: none;
  padding: 0;
  margin: 0;
}

button::after {
  border: none;
}

/* 链接样式重置 */
a {
  color: inherit;
  text-decoration: none;
}

/* 列表样式重置 */
ul, ol {
  list-style: none;
  margin: 0;
  padding: 0;
}

/* 滚动条样式 */
::-webkit-scrollbar {
  width: 6px;
  height: 6px;
}

::-webkit-scrollbar-track {
  background: #f0f5f0;
}

::-webkit-scrollbar-thumb {
  background: #c0d0c0;
  border-radius: 3px;
}

::-webkit-scrollbar-thumb:hover {
  background: #a0b0a0;
}

/* 聚焦样式 */
:focus-visible {
  outline: 2px solid #7EC8A3;
  outline-offset: 2px;
}

/* 通用工具类 */
.container {
  max-width: 600px;
  margin: 0 auto;
}
